@model List<Product>

@{
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchType = ViewBag.SearchType as string;
    var minPrice = ViewBag.MinPrice ?? 0;
    var maxPrice = ViewBag.MaxPrice ?? 100000000;
}

<div class="shop-container">

    <div class="shop-layout">

        <!-- ===== SIDEBAR ===== -->
        <div class="shop-sidebar">
            <form method="get" asp-action="Index" id="filterForm">
                <input type="hidden" name="cateId" value="@ViewBag.SelectedCategory" />
                <input type="hidden" name="keyword" value="@ViewBag.Keyword" />

                <h5 class="filter-title">Select Brand</h5>
                <div class="filter-group" style="margin-bottom: 20px;">
                    <select name="brandId" class="select2-dropdown shop-input" onchange="this.form.submit()">
                        <option value="">-- All Brands --</option>
                        @foreach (var b in ViewBag.Brands as List<Brand>)
                        {
                            <option value="@b.BrandId" selected="@(ViewBag.SelectedBrand == b.BrandId ? "selected" : null)">
                                @b.BrandName
                            </option>
                        }
                    </select>
                </div>

                <hr />

                <h5 class="filter-title">Select Shop</h5>
                <div class="filter-group" style="margin-bottom: 20px;">
                    <select name="shopId" class="select2-dropdown shop-input" onchange="this.form.submit()">
                        <option value="">-- All Shops --</option>
                        @foreach (var s in ViewBag.Shops as List<Shop>)
                        {
                            <option value="@s.ShopId" selected="@(ViewBag.SelectedShop == s.ShopId ? "selected" : null)">
                                @s.ShopName
                            </option>
                        }
                    </select>
                </div>

                <hr />

                <h5 class="filter-title">Price Range</h5>
                <div class="price-filter">
                    @{
                        var displayMax = ViewBag.MaxPrice > 0 ? ViewBag.MaxPrice : 10000000;
                    }
                    <label>From: <b id="minVal">@ViewBag.MinPrice</b></label>
                    <input type="range" name="minPrice" min="0" max="10000000" step="50000" value="@ViewBag.MinPrice" oninput="minVal.innerText = this.value" />

                    <label>To: <b id="maxVal">@displayMax</b></label>
                    <input type="range" name="maxPrice" min="0" max="50000000" step="100000" value="@displayMax" oninput="maxVal.innerText = this.value" />
                </div>

                <button type="submit" class="shop-filter-btn" style="width:100%; margin-top:15px;">Apply Filters</button>
                <a href="/Product" class="btn-clear" style="display:block; text-align:center; margin-top:10px; color:gray; font-size:12px;">Clear All</a>
            </form>
        </div>

        <!-- ===== MAIN ===== -->
        <div class="shop-main">

            <hr />

            <!-- CATEGORY -->
            <div class="shop-category">

                <a href="/Product"
                       class="@(selectedCategory == null ? "shop-cate active" : "shop-cate")">
                    All
                </a>

                @foreach (var c in ViewBag.Categories)
                {
                    if (c.ParentId == null)
                    {
                        <a href="/Product?cateId=@c.CateId"
                               class="@(selectedCategory == c.CateId ? "shop-cate active" : "shop-cate")">
                            @c.CateName
                        </a>
                    }
                }
            </div>

            <hr />

            <!-- PRODUCT LIST -->
            <div class="shop-grid">
                @foreach (var item in Model)
                {
                    <div class="shop-card">

                        <a href="/Product/Details/@item.ProductId" class="shop-link">

                            <!-- ✅ FIX IMAGE -->
                            <img src="@(string.IsNullOrEmpty(item.Image)
                                                               ? Url.Content("~/assets/product-1.jpg")
                                                               : (item.Image.StartsWith("uploads")
                                                                   ? Url.Content("~/" + item.Image)
                                                                   : Url.Content("~/assets/" + item.Image)))" />

                            <h4>@item.ProductName</h4>
                            <p>@item.Price.ToString("N0") VNĐ</p>
                        </a>

                        <div class="shop-actions-group">

                            <!-- BUY NOW -->
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="actionType" value="buyNow" />

                                <button type="submit" class="shop-buy-btn">⚡ Buy Now</button>
                            </form>

                            <!-- ADD TO CART -->
                            <form onsubmit="addToCart(event, @item.ProductId, '@(string.IsNullOrEmpty(item.Image) ? Url.Content("~/assets/product-1.jpg") : Url.Content("~/" + item.Image))', this)">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />

                                <button type="submit" class="shop-cart-btn">
                                    🛒 Add to Cart
                                </button>
                            </form>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>

    function addToCart(event, productId, imgSrc, form) {
        event.preventDefault();

        let token = form.querySelector("input[name='__RequestVerificationToken']").value;

        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'productId=' + productId +
                  '&quantity=1' +
                  '&__RequestVerificationToken=' + token
        })
        .then(res => res.json())
        .then(data => {

            if (data.redirect) {
                window.location.href = data.redirect;
                return;
            }

            animateCart(data.count, imgSrc, form);
        });
    }

    function animateCart(count, imgSrc, startElement) {
        const badge = document.getElementById("cart-count");
        if (badge) badge.innerText = count;

        const cart = document.querySelector(".floating-cart");
        if (!cart) return;

        const img = document.createElement("img");
        img.src = imgSrc;
        img.style.position = "fixed";
        img.style.zIndex = 999;

        document.body.appendChild(img);

        const start = startElement.getBoundingClientRect();
        const end = cart.getBoundingClientRect();

        img.style.left = start.left + "px";
        img.style.top = start.top + "px";
        img.style.width = "80px";

        setTimeout(() => {
            img.style.left = end.left + "px";
            img.style.top = end.top + "px";
            img.style.width = "20px";
            img.style.opacity = "0.5";
        }, 10);

        setTimeout(() => img.remove(), 800);
    }

</script>