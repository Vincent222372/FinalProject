@model List<FinalProject.Models.User>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Seller Management";
}

<h2 class="admin-title">👥 Seller Management</h2>

<div class="table-responsive">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Account Info</th>
                <th>Shop Status</th>
                <th>Registration Date</th>
                <th>Account Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                            {
                                <img src="@user.AvatarUrl" alt="Avatar" style="width: 35px; height: 35px; border-radius: 50%;" />
                            }
                            <div>
                                <div style="font-weight: bold;">@user.FullName</div>
                                <div style="font-size: 11px; color: #666;">@user.Email</div>
                            </div>
                        </div>
                    </td>

                    <td>
                        @if (user.MyShop != null)
                        {
                            <div style="font-size: 13px;">
                                <span style="color: #b07d4f; font-weight: bold;">@user.MyShop.ShopName</span>
                                @if (user.MyShop.IsVerified)
                                {
                                    <span title="Verified Shop" style="color: #1d9bf0; cursor: help;">✔</span>
                                }
                                <div style="font-size: 11px; color: #888;">@user.MyShop.City, @user.MyShop.Country</div>
                            </div>
                        }
                        else
                        {
                            <i style="color: #ccc; font-size: 12px;">No shop profile created</i>
                        }
                    </td>

                    <td style="font-size: 12px;">
                        @user.CreatedAt.ToString("dd/MM/yyyy")
                    </td>

                    <td>
                        @if (user.IsBanned)
                        {
                            <span class="badge bg-danger">Banned</span>
                        }
                        else if (!user.IsActive)
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>

                    <td>
                        <div style="display: flex; gap: 5px;">
                            @if (user.MyShop != null && !user.MyShop.IsVerified)
                            {
                                <form asp-action="ApproveSeller" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    <button type="submit" class="admin-btn" style="background-color: #28a745;">Verify Shop</button>
                                </form>
                            }

                            @if (!user.IsBanned)
                            {
                                <form asp-action="BanSeller" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    <button type="submit" class="admin-btn" style="background-color: #dc3545;" onclick="return confirm('Ban this user and their shop?')">Ban</button>
                                </form>
                            }
                            else
                            {
                                @* SỬA TẠI ĐÂY: Đổi @item.Id thành @user.Id *@
                                <form asp-action="UnbanSeller" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    <button type="submit" class="admin-btn" style="background-color: #28a745;">Unban</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>