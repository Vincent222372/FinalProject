@model FinalProject.Models.Carts

<h2>🛒 Your Cart</h2>

@if (Model == null || Model.CartItems == null || Model.CartItems.Count == 0)
{
    <p>Cart is empty!</p>
}
else
{
    <table border="1" cellpadding="10">
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th>Action</th>
        </tr>

        @foreach (var item in Model.CartItems)
        {
            <tr>
                <td>@item.Product?.ProductName</td>
                <td>@item.Product?.Price.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) đ</td>

                <td>
                    <a href="/Cart/Decrease/@item.CartItemId">-</a>
                    @item.Quantity
                    <a href="/Cart/Increase/@item.CartItemId">+</a>
                </td>

                <td>
                    @((item.Quantity * (item.Product?.Price ?? 0)).ToString("N0"))
                </td>

                <td>
                    <a href="/Cart/Remove/@item.CartItemId">Remove</a>
                </td>
            </tr>
        }
    </table>

    <h3>
        Total:
        @Model.CartItems.Sum(i => i.Quantity * (i.Product?.Price ?? 0)).ToString("N0")
    </h3>

    <a href="/Order/Checkout">👉 Checkout</a>
}