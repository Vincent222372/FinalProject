@model List<FinalProject.Models.User>

    <h2>Users</h2>

    <table class="table">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Action</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.UserName</td>
                <td>@item.Email</td>
                <td>@item.IsActive</td>

                <td>
                    <a asp-action="LockUser" asp-route-id="@item.Id">Lock</a>
                    <a asp-action="UnlockUser" asp-route-id="@item.Id">Unlock</a>
                </td>

            </tr>
        }
    </table>
