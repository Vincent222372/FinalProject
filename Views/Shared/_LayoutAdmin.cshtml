@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using FinalProject.Controllers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: #212529;
            color: white;
            width: 250px;
            position: fixed;
            transition: all 0.3s;
        }

            .sidebar .nav-link {
                color: rgba(255,255,255,0.8);
                padding: 12px 20px;
                border-radius: 0;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background: #343a40;
                    color: #fff;
                    border-left: 4px solid #0d6efd;
                }

        .main-content {
            margin-left: 250px;
            padding: 20px;
        }

        .top-navbar {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 10px 20px;
        }

        .card {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="sidebar d-flex flex-column">
        <div class="p-3 mb-4 text-center">
            <h4 class="fw-bold">FASHION ADMIN</h4>
            <hr class="bg-secondary">
        </div>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                @* Action Index nằm trong AdminController.System.cs *@
                <a asp-controller="Admin" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li>
                @* Action Products nằm trong AdminController.Product.cs *@
                <a asp-controller="Admin" asp-action="Products" class="nav-link">
                    <i class="bi bi-bag-check me-2"></i> Product Manager
                </a>
            </li>
            <li>
                @* Action Orders nằm trong AdminController.Order.cs *@
                <a asp-controller="Admin" asp-action="Orders" class="nav-link">
                    <i class="bi bi-cart3 me-2"></i> Order Manager
                </a>
            </li>
            <li>
                @* Action Users nằm trong AdminController.User.cs *@
                <a asp-controller="Admin" asp-action="Users" class="nav-link">
                    <i class="bi bi-people me-2"></i> User Manager
                </a>
            </li>
            <li>
                @* Action Settings nằm trong AdminController.System.cs *@
                <a asp-controller="Admin" asp-action="Settings" class="nav-link">
                    <i class="bi bi-gear me-2"></i> System Manager
                </a>
            </li>
        </ul>
        <div class="p-3">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100 btn-sm">
                <i class="bi bi-box-arrow-left me-1"></i> Logout
            </a>
        </div>
    </div>

    <div class="main-content">
        <header class="top-navbar d-flex justify-content-between align-items-center mb-4 rounded shadow-sm">
            <h5 class="m-0">@ViewData["Title"]</h5>
            <div class="user-info d-flex align-items-center">
                <span class="me-3 text-muted">Xin chào, <strong>@User.Identity.Name</strong></span>
                <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=random" class="rounded-circle" width="35">
            </div>
        </header>

        <main role="main">
            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMsg"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>