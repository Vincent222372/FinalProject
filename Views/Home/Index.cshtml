@model FinalProject.ViewModels.HomeViewModel

<!-- HERO -->

<section class="hero" id="heroSlide">
    <div class="hero-content">
        <h1>NEW COLLECTION 2026</h1>
        <p>Minimal • Streetwear • Local Brand</p>
        <a href="/Product?from=home" class="hero-btn">
            SHOP NOW
        </a>
    </div>
</section>

<!-- FEATURED -->

<section class="featured">

    <h2>Featured Products</h2>

    <div class="product-grid">

        <div class="product-card">
            <img src="/assets/arrival-3.jpg">
            <h3>Oversize Tee</h3>
            <p>320.000đ</p>
        </div>

        <div class="product-card">
            <img src="/assets/arrival-1.jpg">
            <h3>Street Hoodie</h3>
            <p>520.000đ</p>
        </div>

        <div class="product-card">
            <img src="/assets/arrival-2.jpg">
            <h3>Basic Jacket</h3>
            <p>790.000đ</p>
        </div>

    </div>

</section>


<section class="my-5">
    <h2 class="text-center mb-4">🔥 Sale </h2>

    <!-- Tabs -->
    <ul class="nav nav-tabs justify-content-center" id="saleTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#mens">
                Men's Fashion
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#womens">
                Women's Fashion
            </button>
        </li>
        
    </ul>

    <div class="tab-content mt-4">
        <!-- TAB MEN -->
        <div class="tab-pane fade show active" id="mens">
            <div class="row">
                @foreach (var product in Model.MensProducts)
                {
                    var discountPercent = (int)Math.Round(
                        (product.Price - product.PromotionPrice) / product.Price * 100);

                    <div class="col-md-4 mb-4">
                        <div class="card h-100 text-center shadow-sm">
                            <img src="~/assets/white-shirt.jpg"
                                 class="card-img-top"
                                 alt="@product.ProductName">
                                <div class="card-body">
                                    <h5 class="card-title">@product.ProductName</h5>
                                    <p class="text-muted text-decoration-line-through">
                                        @product.Price.ToString("N0") đ
                                    </p>
                                    <h6 class="text-danger fw-bold">
                                        @product.PromotionPrice.ToString("N0") đ (-@discountPercent%)
                                    </h6>
                                    <a asp-controller="Product"
                                           asp-action="Details"
                                           asp-route-id="@product.ProductID"
                                           class="btn btn-outline-dark btn-sm">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- TAB WOMEN -->
            <div class="tab-pane fade" id="womens">
                <div class="row">
                    @foreach (var product in Model.WomensProducts)
                    {
                        var discountPercent = (int)Math.Round(
                            (product.Price - product.PromotionPrice) / product.Price * 100);

                        <div class="col-md-4 mb-4">
                            <div class="card h-100 text-center shadow-sm">
                                <img src="~/assets/header.png"
                                     class="card-img-top"
                                     alt="@product.ProductName">
                                    <div class="card-body">
                                        <h5 class="card-title">@product.ProductName</h5>
                                        <p class="text-muted text-decoration-line-through">
                                            @product.Price.ToString("N0") đ
                                        </p>
                                        <h6 class="text-danger fw-bold">
                                            @product.PromotionPrice.ToString("N0") đ (-@discountPercent%)
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

               
            </section>
            <script>
                const images = [
                    '/imagess/anh1.jpg',
                    '/imagess/anh2.jpg',
                    '/imagess/anh3.jpg'
                ];

                let index = 0;
                const hero = document.getElementById("heroSlide");

                function changeSlide() {
                    hero.style.backgroundImage = `url('${images[index]}')`;
                    index = (index + 1) % images.length;
                }

                changeSlide();
                setInterval(changeSlide, 3000);
            </script>