<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Fashion Store</title>

    <link rel="stylesheet" href="~/css/site.css" />

    <style>

        body {
            margin: 0;
            font-family: Arial;
        }

        .navbar {
            background: #111;
            color: white;
            padding: 18px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 26px;
            font-weight: bold;
        }

        .menu a {
            color: white;
            text-decoration: none;
            margin-left: 30px;
            font-size: 16px;
        }

            .menu a:hover {
                color: #bbb;
            }

        .container {
            padding: 40px 60px;
        }

    </style>

</head>

<body>


        <nav class="navbar">

            <div class="logo">
                FASHION
            </div>

            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li><a href="/Shop">Shop</a></li>
                <li><a href="/Account/Login">Login</a></li>
                <li><a href="/Account/Register">Register</a></li>
            </ul>

            <button id="themeToggle">🌙</button>

        </nav>

    <div class="container">
        @RenderBody()
    </div>
    <script src="~/js/theme.js"></script>

</body>
</html>