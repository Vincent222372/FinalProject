@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Dashboard";
}
@model List<FinalProject.Models.SystemLog>

<h2 class="admin-title">📜 System Logs</h2>

<div class="table-responsive">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Details</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Timestamp</td>
                    <td>@log.UserId</td>

                    <td>
                        <span class="admin-badge badge-warning">
                            @log.Action
                        </span>
                    </td>

                    <td>@log.Details</td>
                </tr>
            }
        </tbody>
    </table>
</div>