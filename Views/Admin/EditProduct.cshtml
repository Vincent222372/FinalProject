@model FinalProject.Models.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-edit me-2"></i> Edit Product Details</h5>
                    <a href="/Admin/Products" class="btn btn-sm btn-light text-primary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProduct" method="post">
                        @* --- TRƯỜNG ẨN ĐỂ TRÁNH LỖI NULL DB --- *@
                        <input type="hidden" asp-for="ProductId" />
                        <input type="hidden" asp-for="Detail" />
                        <input type="hidden" asp-for="ProductDescription" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" asp-for="ShopId" />
                        <input type="hidden" asp-for="BrandId" />
                        <input type="hidden" asp-for="ListImages" />
                        <input type="hidden" asp-for="ViewCount" />
                        <input type="hidden" asp-for="Hot" />
                        <input type="hidden" asp-for="VAT" />
                        <input type="hidden" asp-for="SeoTitle" />

                        <div class="row">
                            @* Cột bên trái: Thông tin cơ bản *@
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Product Name</label>
                                    <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
                                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Price ($)</label>
                                            <div class="input-group">
                                                <span class="input-group-text">$</span>
                                                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Status</label>
                                            <select asp-for="Status" class="form-select">
                                                <option value="true">Active (Show)</option>
                                                <option value="false">Hidden</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Category</label>
                                    <select asp-for="CateId" class="form-select">
                                        @if (ViewBag.Categories != null)
                                        {
                                            foreach (var c in ViewBag.Categories)
                                            {
                                                <option value="@c.CateId">@c.CateName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            @* Cột bên phải: Hình ảnh preview *@
                            <div class="col-md-5 border-start ps-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Main Image FileName</label>
                                    <input asp-for="Image" id="imageInput" class="form-control" />
                                    <div class="mt-3 text-center">
                                        <p class="small text-muted mb-1">Current Image Preview:</p>
                                        <img id="previewImg" src="/assets/@Model.Image"
                                             class="img-thumbnail" style="max-height: 200px; width: auto;"
                                             onerror="this.src='/assets/no-image.png';" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="reset" class="btn btn-outline-secondary px-4">Reset</button>
                            <button type="submit" class="btn btn-primary px-5">
                                <i class="fas fa-save me-1"></i> Update Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động cập nhật ảnh preview khi thay đổi tên file trong ô input
        document.getElementById('imageInput').addEventListener('input', function() {
            var fileName = this.value;
            document.getElementById('previewImg').src = '/assets/' + fileName;
        });
    </script>
}