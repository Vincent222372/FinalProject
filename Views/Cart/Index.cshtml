@model List<FinalProject.Models.CartItems>

<a asp-controller="Product"
       asp-action="Index"
       class="admin-btn">
    ← Quay lại
</a>

<div class="shop-container">

    <h2 class="shop-title-page">🛒 Your Cart</h2>

    @if (Model == null || Model.Count == 0)
    {
        <p class="shop-empty">Cart is empty!</p>
    }
    else
    {
        <div class="cart-box">

            <table class="cart-table">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@(string.IsNullOrEmpty(item.Image)
                                                                                             ? Url.Content("~/assets/product-1.jpg")
                                                                                             : Url.Content("~/assets/" + item.Image))"
                                 class="cart-img" />
                        </td>

                        <td>@item.ProductName</td>

                        <td>@item.Price</td>

                        <td>
                            <span class="cart-qty">
                                @item.Quantity
                            </span>
                        </td>

                        <td class="cart-total">
                            @((item.Price * item.Quantity).ToString("N0")) VNĐ
                        </td>

                        <td>

                            <!-- ❌ XÓA -->
                            <a href="/Cart/Remove/@item.ProductID"
                                   class="cart-remove">
                                ❌
                            </a>

                            <!-- 💳 BUY NOW -->
                            <form asp-controller="Cart" asp-action="Checkout" method="post" style="margin-top:5px;">

                                <input type="hidden" name="FullName" value="Guest" />
                                <input type="hidden" name="SingleProductId" value="@item.ProductID" />

                                <button name="PaymentMethod" value="Momo" class="buy-now-btn">
                                    Buy Now
                                </button>

                            </form>


                        </td>
                    </tr>
                }
            </table>

        </div>

        <!-- 💰 TOTAL -->
        <div class="cart-summary">
            Total:
            <span>
                @Model.Sum(x => x.Price * x.Quantity).ToString("N0") VNĐ
            </span>
        </div>

        <!-- 💳 THANH TOÁN TOÀN BỘ -->
        <div class="cart-checkout">

            <form asp-controller="Cart" asp-action="Checkout" method="post">

                <input type="hidden" name="FullName" value="Guest" />

                <h5>Payment Method</h5>
                
                <div class="payment-methods">
                    <label>
                        <input type="radio" name="PaymentMethod" value="COD" checked />
                        COD
                    </label>

                    <label>
                        <input type="radio" name="PaymentMethod" value="Momo" />
                        MoMo
                    </label>

                    <label>
                        <input type="radio" name="PaymentMethod" value="ZaloPay" />
                        ZaloPay
                    </label>
                </div>

                <button class="checkout-btn">
                    Checkout All
                </button>

            </form>

        </div>
    }

</div>