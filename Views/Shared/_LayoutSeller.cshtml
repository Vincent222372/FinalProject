<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Seller Dashboard</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <style>
        body {
            margin: 0;
            font-family: Arial;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            background: #2c3e50;
            color: white;
            padding-top: 20px;
        }

        .sidebar a {
            display: block;
            color: white;
            padding: 12px;
            text-decoration: none;
        }

        .sidebar a:hover {
            background: #34495e;
        }

        .content {
            margin-left: 250px;
            padding: 20px;
        }

        .title {
            font-size: 20px;
            font-weight: bold;
            padding: 10px;
        }
    </style>
</head>

<body>

    <!-- 🔥 SIDEBAR -->
    <div class="sidebar">
        <div class="title">SELLER HUB</div>

        <a href="/SellerDashboard">📊 Dashboard</a>
        <a href="/SellerProduct">📦 Sản phẩm</a>
        <a href="/SellerOrder">🧾 Đơn hàng</a>
        <a href="/SellerShop">🏪 Shop</a>
        <a href="/SellerShop/Reviews">⭐ Reviews</a>

        <hr />
        <a href="/">🏠 Về trang chính</a>
        <a href="/Account/Logout">🚪 Logout</a>
    </div>

    <!-- 🔥 CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

</body>
</html>