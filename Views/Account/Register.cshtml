@{
    ViewData["Title"] = "Register";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<div class="register-wrapper">
    <div class="register-card">

        <h2>Create Account</h2>
        <p class="subtitle">Join our fashion community</p>

        <form method="post" action="/Account/Register">

           

            <div class="input-group">
                <label class="input-label">Full Name</label>
                <input type="text" name="FullName" placeholder="Nguyen Van A" required>
            </div>

            <div class="input-group">
                <label class="input-label">Email Address</label>
                <input type="email" name="Email" placeholder="Example@gmail.com" required>
            </div>

            <div class="input-group">
                <label class="input-label">Password</label>

                <input type="password"
                       id="password"
                       name="Password"
                       placeholder="Enter your password"
                       onkeyup="checkStrength()"
                       required
                       onfocus="showRule()">

                <div id="strengthBar"></div>
                <span id="strengthText"></span>
                <div id="passwordRule" style="display:none; margin-top:10px;">
                    <b>Password must contain:</b>
                    <ul>
                        <li id="rule-length">At least 8 characters</li>
                        <li id="rule-upper">1 uppercase letter</li>
                        <li id="rule-number">1 number</li>
                        <li id="rule-special">1 special character</li>
                    </ul>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">Confirm Password</label>

                <input type="password"
                       id="confirmPassword"
                       name="ConfirmPassword"
                       placeholder="Re-enter your password"
                       required
                       onfocus="hideRule()"
                       onkeyup="checkConfirm()">

                <span id="confirmText"></span>
            </div>

            <button class="register-btn">
                Create Account
            </button>

        </form>

        <div class="divider">
            <span>OR</span>
        </div>

        <button class="google-btn"
                onclick="window.location.href='/Account/GoogleLogin'">

            <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png">

            Register with Google

        </button>

        <p class="login-link">
            Already have account?
            <a href="/Account/Login">Login</a>
        </p>

        <p style="color:red">@ViewBag.Error</p>

    </div>
</div>

<script>
    function showRule(){
        var rule = document.getElementById("passwordRule");
        rule.style.display = "block";
    }

    function checkStrength(){
        var password = document.getElementById("password").value;

        var lengthRule = document.getElementById("rule-length");
        var upperRule = document.getElementById("rule-upper");
        var numberRule = document.getElementById("rule-number");
        var specialRule = document.getElementById("rule-special");

        // DEBUG (nếu không chạy sẽ biết ngay)
        console.log("typing...");

        // LENGTH
        if(password.length >= 8){
            lengthRule.style.color = "green";
        } else {
            lengthRule.style.color = "red";
        }

        // UPPER
        if(password.match(/[A-Z]/)){
            upperRule.style.color = "green";
        } else {
            upperRule.style.color = "red";
        }

        // NUMBER
        if(password.match(/[0-9]/)){
            numberRule.style.color = "green";
        } else {
            numberRule.style.color = "red";
        }

        // SPECIAL
        if(password.match(/[!%*?&]/)){
            specialRule.style.color = "green";
        } else {
            specialRule.style.color = "red";
        }
    }
</script>
