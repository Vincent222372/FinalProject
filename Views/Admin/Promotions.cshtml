@model List<FinalProject.Models.Promotion>

<h2>Promotions</h2>

<form asp-action="CreatePromotion" method="post">
    <input name="Name" placeholder="Name" />
    <input name="DiscountPercent" placeholder="Discount" />
    <button>Add</button>
</form>

@foreach (var item in Model)
{
    <div>
        @item.Name - @item.DiscountPercent %

        <a asp-action="DeletePromotion"
           asp-route-id="@item.PromotionID">
            Delete
        </a>

    </div>
}