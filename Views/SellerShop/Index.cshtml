@model FinalProject.Models.Shop

@{
    ViewData["Title"] = "Shop Manager";
    Layout = "_LayoutSeller";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="~/@Model.LogoUrl" class="img-fluid rounded mb-3" style="max-height: 150px;" alt="Logo" />
                    }
                    <h3 class="card-title">@Model.ShopName</h3>
                    <hr />
                    <div class="text-start">
                        <p><strong>Address:</strong> @Model.ShopAddress</p>
                        <p><strong>City:</strong> @Model.City</p>
                        <p><strong>Country:</strong> @Model.Country</p>
                        <p><strong>Contact:</strong> @Model.ContactEmail / @Model.ContactPhone</p>
                    </div>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary btn-sm" asp-action="Edit">Edit Info</a>
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Reviews">Reviews (@Model.TotalReviews)</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm p-4">
                <h4 class="text-muted border-bottom pb-2">Description</h4>
                <p class="mt-2">@Model.ShopDescription</p>

                <h4 class="text-muted border-bottom pb-2 mt-4">Performance</h4>
                <div class="row text-center mt-3">
                    <div class="col-4">
                        <div class="h3 mb-0">@Model.TotalProducts</div>
                        <small class="text-muted text-uppercase">Products</small>
                    </div>
                    <div class="col-4">
                        <div class="h3 mb-0">@Model.RatingAverage.ToString("0.00")</div>
                        <small class="text-muted text-uppercase">Rating</small>
                    </div>
                    <div class="col-4">
                        <div class="h3 mb-0">@Model.TotalFollowers</div>
                        <small class="text-muted text-uppercase">Followers</small>
                    </div>
                </div>

                <div class="mt-5 pt-3 border-top">
                    <p class="text-muted mb-0 small">Created Date: @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>
    </div>
</div>