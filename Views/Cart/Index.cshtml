@model List<FinalProject.Models.CartItems>

<h2>🛒 Your Cart</h2>

@if (Model == null || Model.Count == 0)
{
    <p>Cart is empty!</p>
}
else
{
    <table border="1" cellpadding="10">
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Total</th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td><img src="@item.Image" width="80" /></td>
                <td>@item.ProductName</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@(item.Price* item.Quantity)</td>
                <td>
                    <a href="/Cart/Remove/@item.ProductID">❌</a>
                </td>
            </tr>
        }
    </table>

    <h3>
        Total: @Model.Sum(x => x.Price * x.Quantity) VNĐ
    </h3>
}