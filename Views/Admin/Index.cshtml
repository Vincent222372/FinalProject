@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Dashboard";
}

<!-- 🔥 MENU ĐƯA LÊN TRÊN -->
<div class="admin-menu mb-4">

    <a asp-action="Users">Users</a>
    <a asp-action="Sellers">Sellers</a>
    <a asp-action="Products">Products</a>
    <a asp-action="Orders">Orders</a>
    <a asp-action="Categories">Categories</a>
    <a asp-action="Promotions">Promotions</a>
    <a asp-action="Revenue">Revenue</a>
    <a asp-action="Settings">Settings</a>
    <a asp-action="Logs">Logs</a>

</div>

<h2 class="admin-title">Admin Dashboard</h2>

<div class="admin-cards">

    <p class="admin-card">Total Users: @ViewBag.Users</p>
    <p class="admin-card">Total Products: @ViewBag.Products</p>
    <p class="admin-card">Total Orders: @ViewBag.Orders</p>

</div>



<hr />
