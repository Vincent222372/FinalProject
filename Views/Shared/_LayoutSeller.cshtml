<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Seller Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }

        .wrapper {
            display: flex;
            align-items: stretch;
        }

        #sidebar {
            min-width: 250px;
            max-width: 250px;
            background: #343a40;
            color: #fff;
            min-height: 100vh;
            transition: all 0.3s;
        }

            #sidebar .sidebar-header {
                padding: 20px;
                background: #2c3136;
                text-align: center;
            }

            #sidebar ul p {
                color: #fff;
                padding: 10px;
            }

            #sidebar ul li a {
                padding: 15px 20px;
                font-size: 1.1em;
                display: block;
                color: #ced4da;
                text-decoration: none;
                border-bottom: 1px solid #474f57;
            }

                #sidebar ul li a:hover {
                    background: #474f57;
                    color: #fff;
                }

            #sidebar ul li.active > a {
                background: #495057;
                color: #fff;
            }

        #content {
            width: 100%;
            padding: 20px;
        }

        .seller-navbar {
            background: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            padding: 15px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h4>SELLER HUB</h4>
            </div>
            <ul class="list-unstyled components">
                <li><a asp-controller="Home" asp-action="Index">🏠 Back to Website</a></li>
                <li><a asp-controller="SellerShop" asp-action="Index">📊 Dashboard</a></li>
                <li><a asp-controller="SellerProduct" asp-action="Index">📦 Manage Products</a></li>
                <li><a asp-controller="SellerOrder" asp-action="Index">📜 Manage Orders</a></li>
                <li><a asp-controller="SellerShop" asp-action="Reviews">⭐ Reviews</a></li>
                <li><a asp-controller="Account" asp-action="Logout">🚪 Logout</a></li>
            </ul>
        </nav>

        <div id="content">
            <nav class="navbar seller-navbar">
                <div class="container-fluid">
                    <span class="navbar-text">
                        Welcome, <strong>@User.Identity.Name</strong>
                    </span>
                </div>
            </nav>

            <div class="container-fluid">
                @if (TempData["SuccessMsg"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMsg"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>