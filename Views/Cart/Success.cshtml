@{
    ViewData["Title"] = "Order Success";
    var method = ViewBag.Method as string;
}

{
  

<div class="shop-container" style="text-align: center; padding: 100px 20px;">
    <div style="font-size: 80px; margin-bottom: 20px;">
        @(method == "Momo" ? "💳" : "📦")
    </div>

    <h2 style="font-family: 'Playfair Display'; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">
        Order Placed Successfully!
    </h2>

    <div style="max-width: 600px; margin: 0 auto; color: #666; line-height: 1.6; margin-top: 20px;">
        <p>
            Thank you for shopping with us.
            @if (method == "Momo")
            {
                <span>Your <strong>Momo</strong> transaction has been confirmed.</span>
            }
            Your order is now being processed and prepared for shipping.
        </p>
        <p style="font-style: italic; font-size: 0.9rem; margin-top: 10px;">
            A confirmation details will be handled by our team shortly.
        </p>
    </div>

    <div style="margin-top: 40px; display: flex; gap: 15px; justify-content: center;">
        <a href="/Product" class="login-btn" style="background: #000 !important; width: auto; padding: 12px 35px; text-decoration: none; color: #fff;">
            CONTINUE SHOPPING
        </a>
        <a href="/" class="details-back" style="border: 1px solid #ddd; padding: 12px 35px; border-radius: 0; text-decoration: none; color: #000;">
            BACK TO HOME
        </a>
    </div>
</div>
<script>
    setTimeout(function () {
        window.location.href = "/Product";
    }, 3000);
</script>
