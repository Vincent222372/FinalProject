@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Dashboard";
}

@model List<FinalProject.Models.Order>
<a href="/Admin" class="btn btn-secondary mb-2">
    ← Back
</a>

<h2 class="admin-title">Orders</h2>

<table class="admin-table">

    <tr>
        <th>ID</th>
        <th>Customer</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var o in Model)
    {
        <tr>

            <td>@o.OrderID</td>

            <td>@o.Customer?.FullName</td>

            <td>@o.OrderStatus</td>

            <td>

                <a href="/Admin/UpdateOrder/@o.OrderID?status=Processing"
                   class="admin-btn">
                    Processing
                </a>

                <a href="/Admin/UpdateOrder/@o.OrderID?status=Shipping"
                   class="admin-btn">
                    Shipping
                </a>

                <a href="/Admin/UpdateOrder/@o.OrderID?status=Completed"
                   class="admin-btn">
                    Done
                </a>

            </td>

        </tr>
    }

</table>
