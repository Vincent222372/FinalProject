@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Dashboard";
}
@model List<FinalProject.Models.Promotion>

<h2 class="admin-title">🎯 Promotions</h2>

<div class="table-responsive">
    <table class="admin-table">
        <tr>
            <th>Name</th>
            <th>Discount</th>
            <th>Status</th>
        </tr>

        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Name %</td>
                <td>
                    <span class="admin-badge badge-success">Active</span>
                </td>
            </tr>
        }
    </table>
</div>