@model FinalProject.ViewModels.HomeViewModel

<!-- HERO -->
<section class="hero" id="heroSlide">
    <div class="hero-content">
        <h1>NEW COLLECTION 2026</h1>
        <p>Minimal • Streetwear • Local Brand</p>
        <a href="/Product?from=home" class="hero-btn">
            SHOP NOW
        </a>
    </div>
</section>

<hr class="my-5" />

<section class="my-5">
    <h2 class="text-center mb-4">🔥Explore the product</h2>

    <!-- TAB HOT / SALE -->
    <div class="text-center mb-3">
        <button class="btn btn-dark me-2 active-tab" onclick="switchMainTab('hot', event)">🔥 HOT</button>
        <button class="btn btn-outline-danger" onclick="switchMainTab('sale', event)">💸 SALE</button>
    </div>

    <!-- SUB TAB -->
    <div class="text-center mb-4 d-none" id="subTabs">
        <button class="btn btn-outline-secondary me-2 active-sub" onclick="switchSubTab('men', event)">Men's Fashion</button>
        <button class="btn btn-outline-secondary" onclick="switchSubTab('women', event)">Women's Fashion</button>
    </div>

    <!-- PRODUCT LIST -->
    <div class="row" id="productContainer"></div>
</section>

<script>
    let currentMain = "hot";
    let currentSub = "men";

    const hotProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HotProducts ?? new List<FinalProject.Models.Product>()));
    const saleProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SaleProducts ?? new List<FinalProject.Models.Product>()));

    function switchMainTab(type, e) {
        currentMain = type;

        document.getElementById("subTabs").classList.remove("d-none");

        document.querySelectorAll(".active-tab").forEach(x => x.classList.remove("active-tab"));
        e.target.classList.add("active-tab");

        renderProducts();
    }

    function switchSubTab(type, e) {
        currentSub = type;

        document.querySelectorAll(".active-sub").forEach(x => x.classList.remove("active-sub"));
        e.target.classList.add("active-sub");

        renderProducts();
    }

    function renderProducts() {

        let data = currentMain === "hot" ? hotProducts : saleProducts;

        // DEBUG xem có data không
        console.log("DATA:", data);

        let html = "";
data.forEach(p => {

    let price = p.Price || 0;
    let discount = p.Promotion?.DiscountPercent || 0;
    let finalPrice = price * (100 - discount) / 100;

    html += `
        <div class="col-md-3 mb-4">
            <div class="card h-100 text-center shadow-sm position-relative">

                ${discount > 0 ? `<span class="badge bg-danger position-absolute top-0 start-0 m-2">-${discount}%</span>` : ""}

                      <img src="/assets/${p.Image}"
         class="card-img-top"
         style="height:220px;object-fit:cover;"
         onerror="this.src='/assets/no-image.png'">

                <div class="card-body">
                    <h6>${p.ProductName}</h6>

                    ${discount > 0 ? `
                        <p class="text-muted text-decoration-line-through">
                            ${price.toLocaleString()} đ
                        </p>
                        <p class="text-danger fw-bold">
                            ${finalPrice.toLocaleString()} đ
                        </p>
                    ` : `
                        <p class="text-danger fw-bold">
                            ${price.toLocaleString()} đ
                        </p>
                    `}

                    <a href="/Product/Details/${p.ProductId}"
                       class="btn btn-dark btn-sm">
                        Xem
                    </a>
                </div>
            </div>
        </div>
    `;
});

        if (html === "") {
                html = `<p class="text-center text-muted">no products</p>`;
        }

        document.getElementById("productContainer").innerHTML = html;
    }

    // 🔥 QUAN TRỌNG: render lần đầu
    renderProducts();
           const heroImages = [
            "/imagess/anh1.jpg",
            "/imagess/anh2.jpg",
            "/imagess/anh3.jpg"
        ];

        let index = 0;

        function changeHero() {
            const hero = document.getElementById("heroSlide");

            hero.style.backgroundImage = `url('${heroImages[index]}')`;

            index++;
            if (index >= heroImages.length) index = 0;
        }

        setInterval(changeHero, 3000);
        changeHero();
</script>

<style>
    .active-tab {
        background: #000 !important;
        color: #fff !important;
    }

    .active-sub {
        background: #ddd !important;
    }
</style>
