@model List<FinalProject.Models.Product>
@{
    string selectedCategoryId = Context.Request.Query["categoryId"];
}

<h2>🛍 Product List</h2>

<p>Total: <b>@Model.Count</b> products</p>

<!-- SEARCH -->
<form method="get" action="/Product/Search" style="margin-bottom:15px;">
    <input type="text" name="keyword" placeholder="Search product..."
           style="padding:5px;width:200px;">
    <button type="submit">Search</button>
</form>

<hr />

<!-- CATEGORY -->
<h3>📂 Category</h3>

<a href="/Product"
   style="margin-right:10px;
          @(string.IsNullOrEmpty(selectedCategoryId) ? "color:red;font-weight:bold" : "")">
    All
</a>

@foreach (var c in ViewBag.Categories)
{
    <a href="/Product?categoryId=@c.CategoryId"
       style="margin-right:10px;
                  @(selectedCategoryId == c.CategoryId.ToString() ? "color:red;font-weight:bold" : "")">
        @c.Name <!-- Changed from @c.CategoryName to @c.Name -->
    </a>
}

<hr />

<!-- PRODUCT LIST -->
<div style="display:flex;flex-wrap:wrap;">

    @if (Model.Count == 0)
    {
        <p>❌ No products found</p>
    }

    @foreach (var item in Model)
    {
        <div style="border:1px solid #ccc;
                        padding:10px;
                        margin:10px;
                        width:220px;
                        border-radius:10px;
                        text-align:center;
                        box-shadow:0 0 5px #ccc;">

            <!-- IMAGE -->
            <img src="@(item.Image ?? "https://via.placeholder.com/150")"
                 style="width:100%;height:150px;object-fit:cover;" />

            <!-- NAME -->
            <h4>@item.ProductName</h4>

            <!-- PRICE -->
            <p style="color:red;font-weight:bold;">
                @item.Price VNĐ
            </p>

            <!-- CATEGORY -->
            <p style="font-size:13px;color:gray;">
                @item.Category?.CateName
            </p>

            <!-- ACTION -->
            <a href="/Product/Details/@item.ProductID">👁 View</a>
            <br /><br />

            <a href="/Cart/AddToCart?productId=@item.ProductID"
               style="background:green;
                          color:white;
                          padding:5px 10px;
                          border-radius:5px;
                          text-decoration:none;">
                🛒 Add to Cart
            </a>

        </div>
    }

</div>