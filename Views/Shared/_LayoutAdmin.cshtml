@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using FinalProject.Controllers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/FinalProject.styles.css" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #f8f9fa;
            }

            .main-content {
                padding: 20px;
            }

            .top-navbar {
                background: #fff;
                border-bottom: 1px solid #dee2e6;
                padding: 10px 20px;
            }

            .card {
                border: none;
                border-radius: 10px;
                box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
            }

            /* NÚT QUAY LẠI */
            .btn-back {
                border-radius: 20px;
                padding: 5px 12px;
            }
    </style>
</head>

<body>

    <div class="main-content">

        <!-- HEADER -->
        <header class="top-navbar d-flex justify-content-between align-items-center mb-3 rounded shadow-sm">

            <!-- LEFT -->
            <div class="d-flex align-items-center gap-2">
                <!-- 🔥 NÚT QUAY LẠI -->
                <a href="/Home/Index" onclick="goHome(event)" class="btn btn-outline-dark btn-sm btn-back">
                    HOME
                </a>

                <h5 class="m-0">@ViewData["Title"]</h5>
            </div>

            <!-- RIGHT -->
            <div class="user-info d-flex align-items-center">
                <span class="me-3 text-muted">
                    HELLO, <strong>@User.Identity.Name</strong>
                </span>
                <img src="https://ui-avatars.com/api/?name=@User.Identity.Name"
                     class="rounded-circle" width="35">
            </div>

        </header>

        <!-- BODY -->
        <main role="main">
            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMsg"]</div>
            }
            @if (TempData["ErrorMsg"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMsg"]</div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
<script>
    function goHome(e) {
        e.preventDefault();

        document.body.classList.add("fade-out");

        setTimeout(() => {
            window.location.href = "/Home/Index";
        }, 400); // đúng với thời gian CSS
    }
</script>