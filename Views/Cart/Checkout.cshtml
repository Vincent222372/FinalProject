@model FinalProject.ViewModels.CheckoutVM
@using System.Globalization

@{
    ViewData["Title"] = "Checkout";
    var cart = ViewBag.Cart as List<CartItems> ?? new List<CartItems>();
}

<div class="shop-container">
    <h2 class="admin-title">CHECKOUT</h2>

    <div class="details-container" style="grid-template-columns: 1fr 400px; align-items: start;">

        <div class="cart-box">
            <h4>Shipping Information</h4>
            <form asp-controller="Checkout" asp-action="Checkout" method="post" id="checkoutForm">
                <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 15px; font-weight: 500;"></div>

                <div class="cart-box">
                    <h4>Shipping Information</h4>
                    <form asp-controller="Checkout" asp-action="Checkout" method="post" id="checkoutForm">
                        <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 15px;"></div>

                        <div class="admin-form" style="max-width: 100%; border: none; padding: 0;">
                            <label>Full Name</label>
                            <input asp-for="FullName" class="admin-input" required />

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <label>Phone Number</label>
                                    <input asp-for="PhoneNumber" class="admin-input" required />
                                </div>
                                <div>
                                    <label>City / Province</label>
                                    <input asp-for="City" class="admin-input" required />
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <label>District</label>
                                    <input asp-for="District" class="admin-input" required />
                                </div>
                                <div>
                                    <label>Ward</label>
                                    <input asp-for="Ward" class="admin-input" required />
                                </div>
                            </div>

                            <label>Street Address</label>
                            <input asp-for="Address" class="admin-input" placeholder="House number, Street name..." required />

                            <label>Note (Optional)</label>
                            <textarea asp-for="Note" class="admin-input" rows="3"></textarea>

                            <label style="margin-top: 15px;">Payment Method</label>
                            <div style="display: flex; gap: 20px; margin-top: 10px;">
                                <label><input type="radio" asp-for="PaymentMethod" value="COD" checked> 🚚 COD</label>
                                <label><input type="radio" asp-for="PaymentMethod" value="Momo"> 💳 Momo</label>
                                <label><input type="radio" asp-for="PaymentMethod" value="ZaloPay"> 💳 ZaloPay</label>
                            </div>
                        </div>

                        @* Input ẩn để giữ PromoCode gửi kèm form nếu cần *@
                        <input type="hidden" name="PromotionCode" id="hiddenPromoCode" />
                    </form>
                </div>
            </form>
        </div>

        <div class="cart-box">
            <h4>Order Summary</h4>
            <hr />

            @foreach (var item in cart)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px;">
                    <span>@item.ProductName x @item.Quantity</span>

                    <!-- ✅ FIX GIÁ -->
                    <span>
                        @((item.Price * item.Quantity).ToString("N0", new CultureInfo("vi-VN"))) VNĐ
                    </span>
                </div>
            }
            <div class="promotion-box" style="margin-bottom: 15px;">
                <label style="font-size: 14px; font-weight: bold;">Promotion Code</label>
                <div style="display: flex; gap: 5px; margin-top: 5px;">
                    <input type="text" name="PromoCode" form="checkoutForm" class="admin-input"
                           placeholder="Enter code..." style="margin-bottom: 0; flex: 1;" />
                </div>
                <small class="text-muted">Apply code to get a discount on your total.</small>
            </div>

            <hr />

            <hr />

            <div class="cart-summary" style="text-align: left; font-size: 18px;">
                <strong>Total: </strong>

                <!-- ✅ FIX TOTAL -->
                <span style="color: #b07d4f;">
                    @(((decimal)ViewBag.Total).ToString("N0", new CultureInfo("vi-VN"))) VNĐ
                </span>
            </div>

            <button type="submit" form="checkoutForm" class="login-btn" style="margin-top: 20px; background: #000 !important;">
                PLACE ORDER
            </button>

            <div id="zaloPayQRContainer" style="display:none; margin-top: 20px; text-align: center; border: 1px dashed #ccc; padding: 10px;">
                <p style="font-size: 13px;">Quét mã để thanh toán qua ZaloPay</p>
                <div id="zalo-qr-code"></div>
            </div>

            <a href="/Cart" class="details-back" style="display: block; text-align: center; margin-top: 10px;">
                Back to Cart
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('checkoutForm').addEventListener('submit', function (e) {
            const selectedMethod = document.querySelector('input[name="PaymentMethod"]:checked').value;
            const btn = document.querySelector('.login-btn');

            if (selectedMethod === "Momo") {
                btn.innerHTML = "REDIRECTING TO MOMO...";
                btn.style.background = "#A50064";
            }
            else if (selectedMethod === "ZaloPay") {
                btn.innerHTML = "REDIRECTING TO ZALOPAY...";
                btn.style.background = "#0068FF";
            }
            else {
                btn.innerHTML = "PROCESSING ORDER...";
                btn.style.background = "#333";
            }

            btn.style.opacity = "0.7";
            btn.style.pointerEvents = "none";
        });
    </script>
}