@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager

<div class="auth-group d-inline-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="welcome-text">Greetings, <b>@(User.FindFirst("FullName")?.Value ?? User.Identity.Name)</b></span>

        @if (User.IsInRole("Shop"))
        {
            @* Nếu là chủ shop thì hiện link vào trang quản lý *@
            <a asp-controller="SellerShop" asp-action="Index" class="btn-login-main">Shop Manager</a>
        }
        else if (!User.IsInRole("Admin"))
        {
            @* Nếu là khách hàng bình thường thì hiện link để họ nâng cấp lên shop *@
            <a asp-controller="Account" asp-action="RegisterBusiness" class="link-reg">Open Shop</a>
        }

        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn-logout-link">Logout</button>
        </form>
    }
    else
    {
        <span class="register-text">
            Don't have an account? <a asp-controller="Account" asp-action="Register" class="link-reg">Register</a>
        </span>
        <a asp-controller="Account" asp-action="Login" class="btn-login-main">Login</a>
    }
</div>