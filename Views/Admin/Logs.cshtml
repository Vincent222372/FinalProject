@model List<FinalProject.Models.SystemLog>

<h2>System Logs</h2>
<a href="/Admin" class="btn btn-secondary mb-2">
    ← Back
</a>

<table class="table">
    <thead>
        <tr>
            <th>Time</th>
            <th>UserId</th>
            <th>Action</th>
            <th>Details</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Timestamp</td>
                <td>@log.UserId</td>
                <td>@log.Action</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>