@{
    ViewData["Title"] = "Login";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<div class="login-wrapper">

    <!-- LEFT IMAGE -->
    <div class="login-left">
        <img src="~/assets/arrival-1.jpg">
        <div class="overlay-text">
            <h1>FASHION STORE</h1>
            <p>Streetwear • Minimal • Local Brand</p>
        </div>
    </div>

    <!-- RIGHT FORM -->
    <div class="login-right">

        <div class="login-card">

            <h2>Welcome</h2>
            <p class="sub">Login to your account</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger" style="color: red; margin-bottom: 10px; font-size: 0.9rem;">
                    ⚠️ @ViewBag.Error
                </div>
            }

            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert alert-success" style="color: green; margin-bottom: 10px; font-size: 0.9rem;">
                    ✅ @TempData["SuccessMsg"]
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">

                @Html.AntiForgeryToken()

                <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

                <div class="input-box">
                    <span class="icon">📧</span>
                    <input type="email" name="username" placeholder="Email" required>
                </div>

                <div class="input-box">

                    <span class="icon">🔒</span>

                    <input type="password" name="password" id="password" placeholder="Password" oninput="showEye()" required>

                    <span id="eye" class="toggle" onclick="togglePassword()">👁</span>

                </div>

                <div class="options-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-size: 0.85rem;">
                    <label style="display: flex; align-items: center; cursor: pointer; color: #555;">
                        <input type="checkbox" name="RememberMe" value="true" style="margin-right: 8px; cursor: pointer;">
                        Remember me
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" style="text-decoration: none; color: #333; font-weight: 500;">
                        Forgot Password?
                    </a>
                </div>


                <button type="submit" class="login-btn">Login</button>

            </form>

            <div class="divider">OR</div>

            <button class="google-btn"
                     onclick="window.location.href='/Account/GoogleLogin'">
                <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png">
                Login with Google
            </button>

            <script>
                function loginWithGoogle() {
                    // Lấy trạng thái của checkbox RememberMe
                    const isRemember = document.querySelector('input[name="RememberMe"]').checked;
                    // Chuyển hướng kèm theo query string
                    window.location.href = `/Account/GoogleLogin?rememberMe=${isRemember}`;
                }
            </script>

            <p class="register">
                Don't have an account?
                <a href="/Account/Register">Register</a>
            </p>
            <div>
                <a asp-action="ForgotPassword" asp-controller="Account">
                    Forgot Password?
                </a>
            </div>

        </div>

    </div>

</div>

<script>

    function showEye(){

        var password = document.getElementById("password");
        var eye = document.getElementById("eye");

        if(password.value.length > 0){
            eye.style.display = "block";
        }
        else{
            eye.style.display = "none";
        }
    }

    function togglePassword(){

        var password = document.getElementById("password");

        if(password.type === "password"){
            password.type = "text";
        }
        else{
            password.type = "password";
        }

    }

</script>
<script>
    // Hàm showEye và togglePassword cũ của bạn giữ nguyên ở đây
    function showEye() { ... }
    function togglePassword() { ... }
</script>

@if (TempData["RegisterSuccess"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            Swal.fire({
                title: 'Congratulations!',
                text: '@TempData["RegisterSuccess"]',
                icon: 'success',
                confirmButtonText: 'Login Now',
                confirmButtonColor: '#333',
                timer: 4000,
                timerProgressBar: true
            });
        });
    </script>
}