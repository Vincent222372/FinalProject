@model List<Product>

@{
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchType = ViewBag.SearchType as string;
}

<h2>🛍 Product List</h2>

<a asp-action="Create"
   style="background:#007bff;
          color:white;
          padding:8px 15px;
          border-radius:5px;
          text-decoration:none;
          display:inline-block;
          margin-bottom:10px;">
    ➕ Add Product
</a>

<p>Total: <b>@Model.Count</b> products</p>

<!-- SEARCH -->
<form method="get" asp-action="Index" style="margin-bottom:20px;">

    <select name="searchType" style="padding:5px;">
        <option value="name" selected="@(searchType == "name")">🔍 Product Name</option>
        <option value="seo" selected="@(searchType == "seo")">📌 SEO Title</option>
        <option value="keyword" selected="@(searchType == "keyword")">🏷 Meta Keywords</option>
        <option value="desc" selected="@(searchType == "desc")">📝 Description</option>
    </select>

    <input type="text" name="keyword"
           value="@ViewBag.Keyword"
           placeholder="Search product..."
           style="padding:5px;width:200px;" />

    <button type="submit">Search</button>

</form>

<hr />

<!-- CATEGORY -->
<h3>📂 Category</h3>

<a href="/Product"
   style="margin-right:10px;
   @(selectedCategory == null ? "color:red;font-weight:bold" : "")">
    All
</a>

@foreach (var c in ViewBag.Categories)
{
    <a asp-controller="Product"
       asp-action="Index"
       asp-route-categoryId="@c.CateID"
       style="margin-right:10px; @(selectedCategory == c.CateID ? "color:red;font-weight:bold" : "")">
        @c.CateName
    </a>
}

<hr />

<!-- PRODUCT LIST -->
<div style="display:flex;flex-wrap:wrap;">

    @if (Model.Count == 0)
    {
        <p style="color:red;font-weight:bold;">
            ❌ No products found!
        </p>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div style="border:1px solid #ccc;
                        padding:10px;
                        margin:10px;
                        width:220px;
                        border-radius:10px;
                        text-align:center;">

                <!-- CLICK CARD -->
                <a href="/Product/Details/@item.ProductID"
                   style="text-decoration:none;color:black;">

                    <img src="@(string.IsNullOrEmpty(item.Image)
                                     ? Url.Content("~/assets/product-1.jpg")
                                     : Url.Content("~/assets/" + item.Image))"
                         style="width:100%;height:150px;object-fit:cover;" />

                    <h4>@item.ProductName</h4>

                    <p style="color:red;font-weight:bold;">
                        @item.Price VNĐ
                    </p>

                </a>

                <!-- CATEGORY -->
                <p style="color:gray;">
                    @item.Category?.CateName
                </p>

                <!-- ADD TO CART -->
                <a href="/Cart/AddToCart?productId=@item.ProductID"
                   style="background:green;
                          color:white;
                          padding:5px 10px;
                          border-radius:5px;
                          text-decoration:none;">
                    🛒 Add to Cart
                </a>

            </div>
        }
    }

</div>