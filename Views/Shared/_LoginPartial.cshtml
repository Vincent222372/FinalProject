@using Microsoft.AspNetCore.Identity
@using FinalProject.Models
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<div class="auth-group d-inline-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = currentUser?.FullName ?? User.Identity.Name;
        // Lấy avatar, nếu null thì dùng ảnh mặc định
        var avatarUrl = string.IsNullOrEmpty(currentUser?.AvatarUrl)
        ? "/images/default-avatar.png"
        : currentUser.AvatarUrl;

        <div class="user-greeting-wrapper text-end me-2">
            <span class="welcome-text">
                Greetings,
                <a asp-controller="Account" asp-action="Profile" class="user-name-link">
                    <b>@displayName</b>
                </a>
            </span>
            <div class="profile-hint" style="font-size: 0.7rem; color: #888; font-style: italic;">
                Click to view profile
            </div>
        </div>

        <a asp-controller="Account" asp-action="Profile" class="nav-avatar-link">
            <img src="@avatarUrl" alt="Avatar" class="nav-user-avatar">
        </a>
    }
    else
    {
        <span class="register-text">
            Don't have an account? <a asp-controller="Account" asp-action="Register" class="link-reg">Register</a>
        </span>
        <a asp-controller="Account" asp-action="Login" class="btn-login-main">Login</a>
    }
</div>