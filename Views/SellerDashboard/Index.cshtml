@model FinalProject.ViewModels.SellerDashboardVM
@{
    ViewData["Title"] = "My Products";
    var shop = ViewBag.Shop as FinalProject.Models.Shop;

    Layout = "_LayoutSeller";
}


<h2>🔥 Seller Dashboard</h2>

<!-- FILTER -->
<div style="margin-bottom:20px;">
    <button onclick="loadChart(7)">7 ngày</button>
    <button onclick="loadChart(30)">30 ngày</button>
</div>

<!-- KPI -->
<div style="display:flex; gap:20px; margin-bottom:20px;">
    <div class="card">
        💰 Doanh thu<br />
        <b>@Model.TotalRevenue.ToString("N0") VNĐ</b>
    </div>

    <div class="card">
        📦 Đơn hàng<br />
        <b>@Model.TotalOrders</b>
    </div>

    <div class="card">
        🔥 Sản phẩm bán<br />
        <b>@Model.TotalProductsSold</b>
    </div>
</div>

<!-- CHART -->
<canvas id="mainChart" height="100"></canvas>

<hr />

<!-- TOP -->
<h3>🔥 Top sản phẩm</h3>
<table border="1" width="50%">
    <tr>
        <th>Tên</th>
        <th>Đã bán</th>
    </tr>

    @foreach (var item in Model.TopProducts)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.TotalSold</td>
        </tr>
    }
</table>

<!-- STYLE -->
<style>
.card {
    flex:1;
    padding:20px;
    border-radius:10px;
    background:#f5f5f5;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}
</style>

<!-- CHART -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
let chart;

function loadChart(days = 7) {
    fetch(`/SellerDashboard/GetChartData?days=${days}`)
    .then(res => res.json())
    .then(data => {

        let labels = data.map(x => x.date);
        let revenue = data.map(x => x.revenue);
        let profit = data.map(x => x.profit);

        if (chart) chart.destroy();

        const ctx = document.getElementById('mainChart').getContext('2d');

        const gradient1 = ctx.createLinearGradient(0, 0, 0, 300);
        gradient1.addColorStop(0, "rgba(54,162,235,0.5)");
        gradient1.addColorStop(1, "rgba(54,162,235,0)");

        const gradient2 = ctx.createLinearGradient(0, 0, 0, 300);
        gradient2.addColorStop(0, "rgba(75,192,192,0.5)");
        gradient2.addColorStop(1, "rgba(75,192,192,0)");

        chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Doanh thu',
                        data: revenue,
                        borderColor: '#36A2EB',
                        backgroundColor: gradient1,
                        fill: true,
                        tension: 0.4
                    },
                    {
                        label: 'Lợi nhuận',
                        data: profit,
                        borderColor: '#4BC0C0',
                        backgroundColor: gradient2,
                        fill: true,
                        tension: 0.4
                    }
                ]
            },
            options: {
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: ctx =>
                                ctx.dataset.label + ": " +
                                ctx.raw.toLocaleString() + " VNĐ"
                        }
                    }
                }
            }
        });
    });
}

// load lần đầu
loadChart();
</script>

<!-- SIGNALR -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/orderHub")
    .build();

connection.start();

connection.on("NewOrder", () => loadChart());
connection.on("OrderUpdated", () => loadChart());
</script>