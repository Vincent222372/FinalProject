@model FinalProject.Models.Order

@{
    ViewData["Title"] = "Order Details";
    var shop = ViewBag.Shop as FinalProject.Models.Shop;
    var shopItems = ViewBag.ShopItems as IEnumerable<FinalProject.Models.OrderDetails>;
}

<h1>Order #@Model.OrderId</h1>

<p>
    <strong>Date:</strong> @Model.OrderDate.ToString("g")<br />
    <strong>Customer:</strong> @Model.User?.FullName ?? ("User #" + Model.UserId)<br />
    <strong>Order Status:</strong> @Model.OrderStatus<br />
    <strong>Payment Status:</strong> @Model.PaymentStatus<br />
</p>

<h4>Your Items in this Order</h4>
<table class="table">
    <thead>
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in shopItems)
    {
        <tr>
            <td>@item.Product?.ProductName</td>
            <td>@item.Price.ToString("C")</td>
            <td>@item.Quantity</td>
            <td>@(item.Price * item.Quantity).ToString("C")</td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3">Total</th>
            <th>@shopItems.Sum(i => i.Price * i.Quantity).ToString("C")</th>
        </tr>
    </tfoot>
</table>

<div class="mb-3">

    @if (Model.OrderStatus == "Pending")
    {
        <!-- ✅ CONFIRM -->
        <form asp-action="ConfirmOrder" method="post" style="display:inline-block;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderId" />
            <button class="btn btn-success">✔ Confirm Order</button>
        </form>

        <!-- ❌ CANCEL -->
        <form asp-action="CancelOrder" method="post" style="display:inline-block;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderId" />
            <button class="btn btn-danger">✖ Cancel</button>
        </form>
    }

    else if (Model.OrderStatus == "Confirmed")
    {
        <form asp-action="UpdateShipping" method="post" style="display:inline-block;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderId" />
            <input type="hidden" name="status" value="Shipping" />
            <button class="btn btn-info">🚚 Start Shipping</button>
        </form>
    }

    else if (Model.OrderStatus == "Shipping")
    {
        <form asp-action="UpdateShipping" method="post" style="display:inline-block;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderId" />
            <input type="hidden" name="status" value="Completed" />
            <button class="btn btn-success">✔ Complete</button>
        </form>
    }

    <a asp-action="Index" class="btn btn-secondary ms-2">Back to orders</a>

</div>