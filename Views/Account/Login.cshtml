@{
    ViewData["Title"] = "Login";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>

    /* ===== BACKGROUND DARK + GLOW ===== */
    .login-wrapper {
        position: relative;
        overflow: hidden;
    }

        .login-wrapper::before {
            content: "";
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255,255,255,0.08), transparent);
            top: -100px;
            left: -100px;
            filter: blur(120px);
        }

        .login-wrapper::after {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.05), transparent);
            bottom: -100px;
            right: -100px;
            filter: blur(120px);
        }

    /* ===== CARD GLASS EFFECT ===== */
    .login-card {
        background: rgba(255,255,255,0.08) !important;
        backdrop-filter: blur(20px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        animation: fadeUp 0.6s ease;
        transition: 0.4s;
    }

        .login-card:hover {
            transform: translateY(-5px) scale(1.01);
        }

    /* ===== FADE ANIMATION ===== */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== INPUT NÂNG CẤP ===== */
    .input-box input {
        transition: 0.3s;
    }

        .input-box input:focus {
            outline: none;
            border-color: #000;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
        }

    /* ===== ICON MƯỢT ===== */
    .input-box .icon {
        transition: 0.3s;
    }

    .input-box input:focus + .icon {
        transform: scale(1.1);
    }

    /* ===== BUTTON LOGIN ===== */
    .login-btn {
        transition: 0.3s;
        position: relative;
        overflow: hidden;
    }

        .login-btn::after {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: -100%;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: 0.5s;
        }

        .login-btn:hover::after {
            left: 100%;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

    /* ===== GOOGLE BUTTON ===== */
    .google-btn {
        transition: 0.3s;
    }

        .google-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    /* ===== LINK ===== */
    .register a,
    .options-row a {
        position: relative;
    }

        .register a::after,
        .options-row a::after {
            content: "";
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -2px;
            left: 0;
            background: #000;
            transition: 0.3s;
        }

        .register a:hover::after,
        .options-row a:hover::after {
            width: 100%;
        }

    /* ===== IMAGE ZOOM (giống Nike) ===== */
    .login-left img {
        transition: transform 1.2s ease;
    }

    .login-left:hover img {
        transform: scale(1.08);
    }

</style>

<div class="login-wrapper">

    <!-- LEFT IMAGE -->
    <div class="login-left">
        <img src="~/assets/arrival-1.jpg">
        <div class="overlay-text">
            <h1>FASHION STORE</h1>
            <p>Streetwear • Minimal • Local Brand</p>
        </div>
    </div>

    <!-- RIGHT FORM -->
    <div class="login-right">

        <div class="login-card">

            <h2>Welcome</h2>
            <p class="sub">Login to your account</p>

            @if (ViewBag.Error != null)
            {
                <div id="lockout-msg" class="alert alert-danger" style="color: red; margin-bottom: 15px; font-size: 0.9rem; padding: 15px; background: rgba(255,77,77,0.1); border-radius: 8px; border: 1px solid rgba(255,77,77,0.2);">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <span id="lock-icon">⚠️</span>
                        <span id="error-text">@ViewBag.Error</span>
                    </div>

                    @if (ViewBag.SecondsLeft != null)
                    {
                        <div id="countdown-wrapper" style="margin-top: 8px; font-weight: 600; font-family: 'Inter', sans-serif;">
                            Try again in: <span id="timer" style="color: #fff; background: #ff4d4d; padding: 2px 8px; border-radius: 4px; min-width: 40px; display: inline-block; text-align: center;">@ViewBag.SecondsLeft</span> seconds
                        </div>
                    }
                </div>
            }

            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert alert-success" style="color: green; margin-bottom: 10px; font-size: 0.9rem;">
                    ✅ @TempData["SuccessMsg"]
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">

                @Html.AntiForgeryToken()

                <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

                <div class="input-box">
                    <span class="icon">📧</span>
                    <input type="email" name="username" placeholder="Email" required>
                </div>

                <div class="input-box">

                    <span class="icon">🔒</span>

                    <input type="password" name="password" id="password" placeholder="Password" oninput="showEye()" required>

                    <span id="eye" class="toggle" onclick="togglePassword()">👁</span>

                </div>

                <div class="options-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-size: 0.85rem;">
                    <label style="display: flex; align-items: center; cursor: pointer; color: #555;">
                        <input type="checkbox" name="RememberMe" value="true" style="margin-right: 8px; cursor: pointer;">
                        Remember me
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" style="text-decoration: none; color: #333; font-weight: 500;">
                        Forgot Password?
                    </a>
                </div>

                <button type="submit" class="login-btn">Login</button>

            </form>

            <div class="divider">OR</div>

            <button class="google-btn"
                    onclick="window.location.href='/Account/GoogleLogin'">
                <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png">
                Login with Google
            </button>

            <p class="register">
                Don't have an account?
                <a href="/Account/Register">Register</a>
            </p>
            <div>
                <a asp-action="ForgotPassword" asp-controller="Account">
                    Forgot Password?
                </a>
            </div>

        </div>

    </div>

</div>

<script>
    function showEye(){
        var password = document.getElementById("password");
        var eye = document.getElementById("eye");

        if(password.value.length > 0){
            eye.style.display = "block";
        }
        else{
            eye.style.display = "none";
        }
    }

    function togglePassword(){
        var password = document.getElementById("password");

        if(password.type === "password"){
            password.type = "text";
        }
        else{
            password.type = "password";
        }
    }

        // --- NEW LOGIC COUNTDOWN ---
    document.addEventListener("DOMContentLoaded", function () {
        const timerDisplay = document.getElementById("timer");
        const submitBtn = document.querySelector(".login-btn");
        const alertBox = document.getElementById("lockout-msg");
        const errorText = document.getElementById("error-text");
        const lockIcon = document.getElementById("lock-icon");
        const countdownWrapper = document.getElementById("countdown-wrapper");

        if (timerDisplay) {
            let seconds = parseInt(timerDisplay.textContent);

            // Vô hiệu hóa nút Login ngay lập tức
            submitBtn.disabled = true;
            submitBtn.style.opacity = "0.5";
            submitBtn.style.cursor = "not-allowed";

            const countdownInterval = setInterval(function () {
                seconds--;
                timerDisplay.textContent = seconds;

                if (seconds <= 0) {
                    clearInterval(countdownInterval);

                    // Thay đổi giao diện khi hết thời gian khóa
                    errorText.textContent = "Lockout expired. You can try to login again.";
                    lockIcon.textContent = "✅";
                    countdownWrapper.style.display = "none";

                    // Đổi màu alert sang xanh lá cho dễ nhận biết
                    alertBox.style.background = "rgba(46, 204, 113, 0.1)";
                    alertBox.style.color = "#2ecc71";
                    alertBox.style.borderColor = "rgba(46, 204, 113, 0.2)";

                    // Kích hoạt lại nút Login
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = "1";
                    submitBtn.style.cursor = "pointer";
                }
            }, 1000);
        }
    });
</script>

@if (TempData["RegisterSuccess"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        Swal.fire({
        title: 'Congratulations!',
        text: '@TempData["RegisterSuccess"]',
        icon: 'success',
        confirmButtonText: 'Login Now',
        confirmButtonColor: '#333',
        timer: 4000,
        timerProgressBar: true
        });
        });
    </script>
}