@model List<Product>

@{
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var searchType = ViewBag.SearchType as string;
    var minPrice = ViewBag.MinPrice ?? 0;
    var maxPrice = ViewBag.MaxPrice ?? 100000000;
}

<div class="shop-container">

    <div class="shop-layout">

        <!-- ===== SIDEBAR ===== -->
        <div class="shop-sidebar">
            <h5 class="filter-title">Filter by price</h5>

            <!-- ✅ SUB CATEGORY -->
            @{
                var categories = ViewBag.Categories as List<ProductCategory>;

                int? currentParent = null;

                if (selectedCategory != null && categories != null)
                {
                    var current = categories
                        .FirstOrDefault(x => x.CateID == selectedCategory);

                    if (current != null)
                    {
                        currentParent = current.ParentID ?? current.CateID;
                    }
                }
            }

            @if (currentParent != null)
            {
                var hasChild = false;

                foreach (var c in ViewBag.Categories)
                {
                    if (c.ParentID == currentParent)
                    {
                        hasChild = true;
                        break;
                    }
                }

                if (hasChild)
                {
                    <hr />
                    <h5 class="filter-title">Sub Categories</h5>

                    <div class="shop-subcategory">
                        @foreach (var sub in ViewBag.Categories)
                        {
                            if (sub.ParentID == currentParent)
                            {
                                <div>
                                    <a href="/Product?cateId=@sub.CateID"
                                           class="shop-cate @(selectedCategory == sub.CateID ? "active" : "")">
                                        └ @sub.CateName
                                    </a>
                                </div>
                            }
                        }
                    </div>
                }
            }

            <!-- PRICE FILTER -->
            <form method="get" asp-action="Index">
                <input type="hidden" name="cateId" value="@selectedCategory" />
                <input type="hidden" name="keyword" value="@ViewBag.Keyword" />
                <input type="hidden" name="searchType" value="@searchType" />

                <div class="price-filter">
                    <label>Price from: <b id="minPriceValue">@minPrice</b> VNĐ</label>
                    <input type="range"
                           name="minPrice"
                           min="0"
                           max="1000000"
                           value="@minPrice"
                           oninput="updatePriceValues()" />

                    <label>To: <b id="maxPriceValue">@maxPrice</b> VNĐ</label>
                    <input type="range"
                           name="maxPrice"
                           min="0"
                           max="1000000"
                           value="@maxPrice"
                           oninput="updatePriceValues()" />
                </div>

                <button type="submit" class="shop-filter-btn">
                    Search
                </button>
            </form>

        </div>

        <!-- ===== MAIN ===== -->
        <div class="shop-main">

            <!-- SEARCH -->
            <form method="get" asp-action="Index" class="shop-search">

                <select name="searchType" class="shop-input">
                    <option value="name" selected="@(searchType == "name")">🔍 Product Name</option>
                    <option value="seo" selected="@(searchType == "seo")">📌 SEO Title</option>
                    <option value="keyword" selected="@(searchType == "keyword")">🏷 Meta Keywords</option>
                    <option value="desc" selected="@(searchType == "desc")">📝 Description</option>
                </select>

                <input type="text" name="keyword"
                       value="@ViewBag.Keyword"
                       placeholder="Search product..."
                       class="shop-input" />

                <button type="submit" class="shop-btn">
                    Search
                </button>

            </form>

            <hr />

            <!-- ✅ CATEGORY CHA ONLY -->
            <div class="shop-category">

                <a href="/Product"
                       class="@(selectedCategory == null ? "shop-cate active" : "shop-cate")">
                    All
                </a>

                @foreach (var c in ViewBag.Categories)
                {
                    if (c.ParentID == null) // 👉 chỉ lấy cha
                    {
                        <a href="/Product?cateId=@c.CateID"
                               class="@(selectedCategory == c.CateID ? "shop-cate active" : "shop-cate")">
                            @c.CateName
                        </a>
                    }
                }

            </div>

            <hr />

            <!-- PRODUCT LIST -->
            <div class="shop-grid">

                @if (Model.Count == 0)
                {
                    <p class="shop-empty">❌ No products found!</p>
                }
                else
                {
                    @foreach (var item in Model)
                    {

                       
   

                        <div class="shop-card">

                            <a href="/Product/Details/@item.ProductID" class="shop-link">

                                <img src="@(string.IsNullOrEmpty(item.Image)
                                                                                                         ? Url.Content("~/assets/product-1.jpg")
                                                                                                         : Url.Content("~/assets/" + item.Image))" />

                                <div class="shop-body">
                                    <h4>@item.ProductName</h4>

                                    @{
                                        var now = DateTime.Now;

                                        var isSale = item.Promotion != null
                                            && item.Promotion.Status
                                            && item.Promotion.StartDate <= now
                                            && item.Promotion.EndDate >= now;

                                        var finalPrice = isSale
                                            ? item.Price * (100 - item.Promotion.DiscountPercent) / 100
                                            : item.Price;
                                    }

                                    <p class="shop-price">

                                        @if (isSale)
                                        {
                                            <span class="badge bg-danger">
                                                -@item.Promotion.DiscountPercent%
                                            </span>

                                            <br />

                                            <span style="text-decoration:line-through;color:gray">
                                                @item.Price.ToString("N0") VNĐ
                                            </span>

                                            <br />

                                            <span style="color:red;font-weight:bold">
                                                @finalPrice.ToString("N0") VNĐ
                                            </span>
                                        }
                                        else
                                        {
                                            <span>@item.Price.ToString("N0") VNĐ</span>
                                        }

                                    </p>

                                    <p class="shop-cate-name">
                                        @item.Category?.CateName
                                    </p>
                                </div>

                            </a>

                            <div class="shop-actions-group">

                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <input type="hidden" name="actionType" value="buyNow" />
                                    <button type="submit" class="shop-buy-btn">⚡ Buy Now</button>
                                </form>

                                <form onsubmit="addToCart(event, @item.ProductID, '@(string.IsNullOrEmpty(item.Image) ? Url.Content("~/assets/product-1.jpg") : Url.Content("~/assets/" + item.Image))', this)">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <button type="submit" class="shop-cart-btn">
                                        🛒 Add to Cart
                                    </button>
                                </form>

                            </div>

                        </div>

                    }

                }

            </div>

        </div>
    </div>
</div>

<script>
      function animateCart(count, imgSrc, startElement) {

        // 🛒 update số
        const badge = document.getElementById("cart-count");
        badge.innerText = count;

        // 🛒 rung badge
        badge.classList.add("animate");
        setTimeout(() => badge.classList.remove("animate"), 400);

        // 🛍️ hiệu ứng bay
        const cart = document.querySelector(".floating-cart");
        if (!cart) return;
        const img = document.createElement("img");

        img.src = imgSrc;
        img.classList.add("fly-img");

        document.body.appendChild(img);

        // vị trí bắt đầu
        const rectStart = startElement.getBoundingClientRect();
        img.style.left = rectStart.left + "px";
        img.style.top = rectStart.top + "px";

        // vị trí kết thúc (cart)
        const rectEnd = cart.getBoundingClientRect();

        setTimeout(() => {
            img.style.left = rectEnd.left + "px";
            img.style.top = rectEnd.top + "px";
            img.style.width = "20px";
            img.style.height = "20px";
            img.style.opacity = "0.5";
        }, 10);

        // xóa sau khi bay xong
        setTimeout(() => {
            img.remove();
        }, 800);
    }
           function addToCart(event, productId, imgSrc, form) {
        event.preventDefault();

        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'productId=' + productId +
                  '&quantity=1' +
                  '&__RequestVerificationToken=' + form.querySelector('input[name="__RequestVerificationToken"]').value
        })
        .then(res => res.json())
        .then(data => {

            // 🔥 nếu chưa login → chuyển sang login
            if (data.redirect) {
                window.location.href = data.redirect;
                return;
            }

            // 👉 đã login thì animate
            if (document.querySelector(".floating-cart")) {
                animateCart(data.count, imgSrc, form);
            }

        });
    }

</script>
